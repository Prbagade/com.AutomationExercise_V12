package com.PageObject;

import org.openqa.selenium.WebDriver;
import org.openqa.selenium.WebElement;
import org.openqa.selenium.support.FindBy;
import org.openqa.selenium.support.ui.Select;

public class RegisterPage extends BasePage  {

	
	public RegisterPage(WebDriver driver) 
	{
		super(driver);
	}
	
	
	
	@FindBy(xpath = "//input[@id='id_gender1']") WebElement rd_Gender;
	@FindBy(xpath = "//input[@id='password']") WebElement txt_Password;
	@FindBy(xpath = "//*[@value=4]") WebElement sel_spDay;
	@FindBy(xpath = "//*[@value='4']") WebElement Sel_Spmonth;
	@FindBy(xpath = "//*[@value='2020']") WebElement Sel_SpYear;
	@FindBy(xpath = "//*[@id='first_name']") WebElement txt_Fname;
	@FindBy(xpath = "//*[@id='last_name']") WebElement txt_Lname;
	@FindBy(xpath = "//*[@id='address1']") WebElement txt_addr;
	@FindBy(xpath = "//*[@value='India']") WebElement drp_country;
	@FindBy(xpath = "") WebElement dd;
	@FindBy(xpath = "") WebElement dd;
	@FindBy(xpath = "") WebElement dd;
	
	public void SelectGender() 
	{
		rd_Gender.click();
	}
	
	public void EnterPassword(String pass) 
	{
		txt_Password.sendKeys(pass);
	}
	
	public void SelectDate() 
	{
		sel_spDay.click();
		
	}
	
	
	
	
	
	public void SelectCountry() 
	{
		drp_country.click();
	}

	
}
