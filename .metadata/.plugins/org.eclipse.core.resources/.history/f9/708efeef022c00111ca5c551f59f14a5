package Pattern_Star;

public class StarPyramid {

	public static void main(String[] args) {
		
		//Star pyramid
		
		for(int line=0;line<=5;line++) 
		{
			for(int sp=0;sp>=5;sp++) 
			{
				System.out.print("_");
			}
			for(int str=5;str>=line;str--) 
			{
				System.out.print("* ");
			}
			System.out.println();
		}

	}

}
