package Star_Programm;

public class Pattern3_ {

	// Revers side * pattern

	public static void main(String[] args) {

		
		for (int line = 1; line <= 4; line++) {

			for (int sp = 3; sp >= line; sp--) {
				System.out.print(" ");
			}
			for (int star = 1; star <= line; star++) {
				System.out.print("*");
			}
			System.out.println();
			
		}
		for(int i=1;i<=4;i++) 
		{
			for(int j=1;j<=i;j++) 
			{
				System.out.print("* ");
			}
			System.out.println();
		}

	}
}
