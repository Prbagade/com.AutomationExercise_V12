		WebDriver driver = new EdgeDriver();

		driver.get("https://testautomationpractice.blogspot.com/");
		driver.manage().window().maximize();

		//total row 
		int rows=driver.findElements(By.xpath("//table[@name='BookTable']//tr")).size();
